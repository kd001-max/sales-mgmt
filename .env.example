# 飞书应用配置
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格(Bitable)配置
BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxxxxxx

# 【新增】飞书OAuth登录回调地址
# 格式: https://你的域名/api/auth/callback
# 必须在飞书开放平台 → 应用功能 → 移动应用登录中配置相同的地址
OAUTH_REDIRECT_URI=https://your-domain.com/api/auth/callback

# 服务器配置
PORT=3000
HOST=0.0.0.0

# 飞书审批流定义编码（可选）
APPROVAL_CODE_SALES_ORDER=xxxxxxxxxx
APPROVAL_CODE_ORDER_CHANGE=xxxxxxxxxx
APPROVAL_CODE_MATERIAL_RETURN=xxxxxxxxxx
APPROVAL_CODE_CONTACT_NOTE=xxxxxxxxxx

# 飞书群机器人Webhook（用于通知）
BOT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 系统管理员飞书ID（用于发送系统通知）
ADMIN_USER_ID=ou_xxxxxxxxxxxxxxxxxxxxxx
